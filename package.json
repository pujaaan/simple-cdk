{
  "name": "simple-cdk-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Build on AWS without being an AWS expert.",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "rm -rf packages/*/dist examples/*/dist examples/*/cdk.out"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
