{
  "name": "@simple-cdk/core",
  "version": "1.0.0",
  "type": "module",
  "description": "Engine for simple-cdk: a convention-over-configuration framework for AWS CDK with a pluggable adapter system for Lambda, DynamoDB, AppSync, and Cognito.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
