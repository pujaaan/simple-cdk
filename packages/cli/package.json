{
  "name": "simple-cdk",
  "version": "4.1.0",
  "type": "module",
  "description": "Simple CLI for AWS CDK — init, list, synth, diff, deploy, destroy. Convention-over-configuration serverless on AWS Lambda, DynamoDB, AppSync, and Cognito.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "simple-cdk": "bin/simple-cdk.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json -w",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@simple-cdk/core": "4.1.0",
    "aws-cdk": "^2.160.0",
    "tsx": "^4.19.0"
  },
  "peerDependencies": {
    "aws-cdk-lib": "^2.160.0",
    "constructs": "^10.3.0"
  },
  "devDependencies": {
    "aws-cdk-lib": "^2.160.0",
    "constructs": "^10.3.0",
    "typescript": "^5.6.3"
  },
  "keywords": [
    "aws",
    "cdk",
    "aws-cdk",
    "cli",
    "deploy",
    "serverless",
    "infrastructure-as-code",
    "iac",
    "typescript",
    "simple-cdk",
    "amplify-alternative"
  ],
  "author": "Pujan Bhatta <pujanb8854@gmail.com> (https://github.com/pujaaan)",
  "license": "MIT",
  "homepage": "https://github.com/pujaaan/simple-cdk/tree/main/packages/cli#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/pujaaan/simple-cdk.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/pujaaan/simple-cdk/issues",
  "publishConfig": {
    "access": "public"
  }
}
